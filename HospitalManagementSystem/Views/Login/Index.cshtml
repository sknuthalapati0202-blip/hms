    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        /* Main Button Container */
        .uae-id-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 20px;
			padding-bottom: 6px; 
            text-decoration: none;
            cursor: pointer;
            border-radius: 8px; /* Matching the rounded corners in your image */
            transition: all 0.2s ease-in-out;
            background-color: #FFFFFF;
            border: 1px solid #1A1A1A; /* Default dark border */
            outline: none;
            box-sizing: border-box;
            height: 44px;
            min-width: 183px;
        }



            /* 1. Hover State: Light grey background */
            .uae-id-btn:hover {
                background-color: #F3F4F6;
            }

            /* 2. Pressed State: Slightly darker grey background */
            .uae-id-btn:active {
                background-color: #E5E7EB;
            }

            /* 3. Focused State: Dark border with inner Gold ring */
            .uae-id-btn:focus {
                border-color: #1A1A1A;
                /* Using box-shadow for the inner gold border so it doesn't shift layout */
                box-shadow: inset 0 0 0 2px #CBA344;
            }

            /* 4. Disabled State: Faded look and 'not-allowed' cursor */
            .uae-id-btn[disabled],
            .uae-id-btn.disabled {
                opacity: 0.5;
                cursor: not-allowed;
                pointer-events: none;
                border-color: #D1D5DB;
            }

            /* Target the text/logo inside the SVG for colors */
            .uae-id-btn svg {
                display: block;
                height: 24px; /* Adjust height to fit inside the 44px button */
                width: auto;
            }

        /* Responsive adjustments */
        @@media (max-width: 400px) {
            .uae-id-btn

        {
            width: 100%;
        }

        }
    </style>
    
</head>
