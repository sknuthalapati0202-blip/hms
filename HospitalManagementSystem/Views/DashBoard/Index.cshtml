@model HospitalManagementSystem.Web.ViewModel.DashBoard.DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
}

<!-- Breadcrumb Section -->
<div class="row" style="padding:0px">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="DashBoard" asp-action="Index"><em class="fa fa-home"></em></a></li>
                <li class="breadcrumb-item">Dashboard</></li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid">
    <h2 style="color:black;">@ViewBag.Title</h2>
    <br />
    <div class="dashboard-container">
        <div class="row no-gutters">
            @* Doctors Card *@
            <div class="col-sm-3">

                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-user-md orange-icon icon"></i>
                        <div class="card-number">@Model.DoctorCount</div>
                        <div class="card-label">Doctors</div>
                    </div>

                </div>
            </div>

            @* Patients Card *@
            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-wheelchair teal-icon icon"></i>
                        <div class="card-number">@Model.PatientCount</div>
                        <div class="card-label">Patients</div>
                    </div>
                </div>
            </div>

            @* Prescriptions Card *@
            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-hospital-o blue-icon"></i>
                        <div class="card-number">@Model.PrescriptionCount</div>
                        <div class="card-label">Prescriptions</div>
                    </div>
                </div>
            </div>

            @* Departments Card *@
            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10">
                        <i class="fa fa-ambulance red-icon"></i>
                        <div class="card-number">@Model.DoctorCount</div>
                        <div class="card-label">Departments</div>
                    </div>
                </div>
            </div>
        </div>

        <br />
        <div class="row no-gutters">
            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-pencil-square-o red-icon"></i>
                        <div class="card-number">@Model.ActiveAppointmentsCount</div>
                        <div class="card-label">Active Appointments</div>
                    </div>
                </div>
            </div>

            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-calendar-check-o teal-icon"></i>
                        <div class="card-number">@Model.PendingAppointmentsCount</div>
                        <div class="card-label">Pending Appointments</div>
                    </div>
                </div>
            </div>

            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10" id="borderId">
                        <i class="fa fa-medkit orange-icon"></i>
                        <div class="card-number">10</div>
                        <div class="card-label">Medicines</div>
                    </div>
                </div>
            </div>

            <div class="col-sm-3">
                <div class="dashboard-card">
                    <div class="col-sm-10">
                        <i class="fa fa-car blue-icon"></i>
                        <div class="card-number">50</div>
                        <div class="card-label">Ambulance Drivers</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <br />

    <div style="padding-top:10px;">
        <div class="border p-3 rounded">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="m-0">Announcements</h5>
                <button class="btn toggle-btn" style="background-color:#30a5ff;" data-bs-toggle="collapse" data-bs-target="#announcementCard">
                    ▼
                </button>
            </div>

            <div id="announcementCard" class="collapse mt-3">
                <div class="card">
                    <div class="card-body">
                        <ul class="list-group">
                            <li class="list-group-item">📢 Announcement 1</li>
                            <li class="list-group-item">📢 Announcement 2</li>
                            <li class="list-group-item">📢 Announcement 3</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script>
        $(document).ready(function () {
            // Handle the toggle button text change on collapse show/hide
            $('#announcementCard').on('show.bs.collapse', function () {
                $(".toggle-btn").text("▲");
            }).on('hide.bs.collapse', function () {
                $(".toggle-btn").text("▼");
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</div>

<style>
    .container-fluid {
        padding: 20px; /* Add container padding */
        margin: 0px;
    }

    .dashboard-container {
        background-color: #f8f9fa; /* Light grey background */
        padding: 0px; /* Remove dashboard container padding */
        border-radius: 0px; /* Remove rounded corners */
        background-color: #ffffff; /* White container background */
    }

    .row.no-gutters {
        margin-right: 0;
        margin-left: 0;
    }

        .row.no-gutters > [class*="col-"] {
            padding-right: 0;
            padding-left: 0;
        }

    .dashboard-card {
        text-align: center;
        background-color: #ffffff; /* White background */
        border-radius: 0px; /* Removed rounded corners */
        box-shadow: 0 0 0px rgba(0, 0, 0, 0.0); /* Removed shadow */
        margin-bottom: 0px;
        border: 1px solid #ffffff; /* Optional: Add a subtle border */
        height: 150px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    #borderId {
        height: 130px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-right: 1px solid #e9ecf2 !important;
    }

    .card-number {
        font-size: 2.5em; /* Increased font size */
        font-weight: 500; /* Adjusted font weight */
        /* margin-top: 5px; */
        margin-bottom: 2px;
        color: #000000; /* Black text for numbers */
    }

    .card-label {
        font-size: 1em; /* Adjusted label size */
        color: #999999; /* Light grey labels */
        font-weight: normal; /* Regular font weight */
        color: black;
    }

    /* Icon styles */
    .fa {
        /* font-size: 3.0em; /* Adjusted Icon Size for larger icons */
        margin-bottom: 5px; /* Adjusted spacing */
    }


    /* Icon colors - Matched to image */
    .blue-icon {
        color: #3498db;
        font-size: 44px !important;
    }

    .orange-icon {
        color: #f39c12;
        font-size: 44px !important;
    }

    .teal-icon {
        color: #1abc9c;
        font-size: 44px !important;
    }

    .red-icon {
        color: #e74c3c;
        font-size: 44px !important;
    }
</style>

<script>
    $(document).ready(function () {
        $(".DashboardMenu").addClass("active");
    });
</script>